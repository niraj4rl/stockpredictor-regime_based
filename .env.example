# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stockobserver
DB_USER=postgres
DB_PASSWORD=change_me
DB_CONNECT_TIMEOUT=3

# Data source: yfinance or upstox
STOCKER_DATA_SOURCE=yfinance

# Upstox (only needed when STOCKER_DATA_SOURCE=upstox)
UPSTOX_API_KEY=your_upstox_api_key
UPSTOX_API_SECRET=your_upstox_api_secret
UPSTOX_REDIRECT_URI=http://localhost:8000/upstox/callback
UPSTOX_ACCESS_TOKEN=your_upstox_access_token

# Optional runtime tuning
STOCKER_PREDICTOR_REFRESH_MINUTES=60
STOCKER_MIN_DATA_ROWS=252
STOCKER_MAX_STALE_DAYS=12
